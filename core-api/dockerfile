# ---- build stage ----
FROM golang:1.26-alpine AS builder
WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/core-api .

# ---- final stage ----
FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /out/core-api /core-api
EXPOSE 8080
ENTRYPOINT ["/core-api"]